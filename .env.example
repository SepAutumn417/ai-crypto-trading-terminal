# ===== 应用 =====
# Keep the API private by default. Use a reverse proxy and authentication before
# deliberately exposing it to a network.
API_HOST=127.0.0.1
API_PORT=8000

# Required for all state-changing API operations. Generate a long random value.
API_TOKEN=
# Required for remote WebSocket connections. It may be different from API_TOKEN.
WS_TOKEN=
# Optional additional passphrase required during server-side trade confirmation.
CONFIRMATION_PASSPHRASE=

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://crypto:crypto@localhost:5432/crypto_terminal
TEST_DATABASE_URL=postgresql+asyncpg://crypto:crypto@localhost:5432/crypto_terminal_test

# ===== 交易所适配器 =====
# true=使用 MockExchange（不下真实订单），false=使用 BitgetExchange
MOCK_EXCHANGE=true
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# ===== CORS =====
# 逗号分隔的来源列表，例如 http://localhost:3000,http://localhost:3001
CORS_ORIGINS=["http://localhost:3000"]

# ===== 前端 =====
NEXT_PUBLIC_API_BASE_URL=

# ===== v0.5 AI 评估 =====
# false=仅使用规则评分器（不调用 LLM），true=启用 LLM 解释层
AI_EVALUATION_ENABLED=false
# LLM 供应商: openai | deepseek | moonshot | custom
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# AI 评估超时秒数（超时降级为 None，不阻塞主流程）
LLM_TIMEOUT_SECONDS=5
